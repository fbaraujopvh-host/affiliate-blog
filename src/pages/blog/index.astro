---

<PageLayout title="Blog — MelhoresProdutos" description="Análises, comparativos e guias de compra dos melhores produtos da Amazon.">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-black text-gray-900 mb-2">Blog</h1>
      <p class="text-gray-600">Análises, comparativos e guias para você comprar melhor.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => <PostCard {...post} />)}
    </div>
  </div>
</PageLayout>
