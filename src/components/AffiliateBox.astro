---
interface Props {
  productName: string;
  productImage: string;
  price: string;
  oldPrice?: string;
  affiliateUrl: string;
  rating?: number;
  note?: string;
}

const {
  productName,
  productImage,
  price,
  oldPrice,
  affiliateUrl,
  rating = 5,
  note,
} = Astro.props;
---

<div class="my-8 border-2 border-amber-300 rounded-2xl overflow-hidden bg-amber-50">
  <div class="bg-amber-400 px-4 py-2 text-center">
    <p class="text-sm font-bold text-white uppercase tracking-wide">Melhor Escolha ⭐</p>
  </div>

  <div class="p-5 flex flex-col sm:flex-row gap-5 items-center">
    <img src={productImage} alt={productName} class="w-32 h-32 object-contain flex-shrink-0" loading="lazy" />

    <div class="flex-1 text-center sm:text-left">
      <h3 class="font-bold text-gray-900 text-lg mb-1">{productName}</h3>

      <!-- Stars -->
      <div class="flex items-center justify-center sm:justify-start gap-1 mb-2 text-amber-400">
        {Array.from({ length: 5 }).map((_, i) => (
          <svg class="w-4 h-4" fill={i < rating ? 'currentColor' : 'none'} stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
          </svg>
        ))}
      </div>

      <div class="mb-3">
        {oldPrice && <p class="text-sm text-gray-400 line-through">{oldPrice}</p>}
        <p class="text-2xl font-black text-gray-900">{price}</p>
      </div>

      {note && <p class="text-xs text-gray-500 mb-3 italic">{note}</p>}

      <a
        href={affiliateUrl}
        target="_blank"
        rel="noopener noreferrer nofollow"
        class="btn-primary"
      >
        Ver na Amazon →
      </a>
    </div>
  </div>

  <p class="text-center text-xs text-gray-400 pb-3 px-4">
    * Link de afiliado — comprando por aqui você apoia o blog sem pagar nada a mais.
  </p>
</div>
